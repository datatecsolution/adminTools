	<parameter name="usuario" class="java.lang.String"/>
	<parameter name="codigo_categoria" class="java.lang.Integer"/>
	<parameter name="bodega" class="java.lang.Integer"/>
	<parameter name="dias" class="java.lang.Integer"/>
	<queryString>
		<![CDATA[SELECT
	articulo.codigo_articulo AS codigo_articulo,
	articulo.articulo AS articulo,
	marcas.descripcion AS marca,
	marcas.codigo_marca AS codigo_marca,
	detalle_factura_compra.fecha_venc AS fecha_venc,
	detalle_factura_compra.cantidad as cantidad_compra,
	f_can_saldo_kardex ( articulo.codigo_articulo,  $P{bodega}  ) AS existencia 
FROM
	articulo
	JOIN marcas ON ( marcas.codigo_marca = articulo.codigo_marca )
	INNER JOIN detalle_factura_compra ON articulo.codigo_articulo = detalle_factura_compra.codigo_articulo 
WHERE (DATE(detalle_factura_compra.fecha_venc) BETWEEN CURDATE() AND DATE_ADD(CURDATE(), INTERVAL $P{dias} DAY)) AND
	marcas.codigo_marca = $P{codigo_categoria} 
      ]]>
	</queryString>
