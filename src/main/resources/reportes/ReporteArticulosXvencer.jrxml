		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="articulo" class="java.lang.String">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="codigo_marca" class="java.lang.Long"/>
	<field name="marca" class="java.lang.String">
